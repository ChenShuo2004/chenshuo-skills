{
  "output": "output/final.mp4",
  "report": "output/final.report.json",
  "target": {
    "width": 1080,
    "height": 1920,
    "fps": 30,
    "crf": 20,
    "preset": "veryfast",
    "audioBitrate": "192k"
  },
  "clips": [
    {
      "source": "materials/clip001.mp4",
      "inSec": 0,
      "outSec": 4.5,
      "role": "hook"
    },
    {
      "source": "materials/clip002.mp4",
      "inSec": 1.2,
      "outSec": 8,
      "role": "body"
    }
  ],
  "bgm": {
    "source": "materials/bgm.mp3",
    "volume": 0.18
  },
  "subtitles": {
    "srt": "materials/captions.srt"
  },
  "keepWorkDir": false
}
